{
    "name": "curlpit/curlpit",
    "version": "1.1.2",
    "description": "A PSR-15 middleware orchestrator for PHP – with branching, looping, and declarative flow control built in",
    "type": "library",
    "license": "MIT",
    "keywords": ["psr-15", "middleware", "flow", "pipeline", "php"],
    "require": {
        "php": "^8.1",
        "psr/http-message": "^1.1|^2.0",
        "psr/http-server-middleware": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "nyholm/psr7": "^1.8"
    },
    "suggest": {
        "nyholm/psr7": "Lightweight PSR-7/17 implementation (recommended)",
        "guzzlehttp/psr7": "Alternative PSR-7/17 implementation",
        "psr/container": "Required to use ContainerApplication with a PSR-11 DI container (php-di/php-di, symfony/dependency-injection, etc.)"
    },
    "autoload": {
        "psr-4": {
            "Curlpit\\Core\\": "src/Core/",
            "Curlpit\\App\\": "src/App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Curlpit\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
